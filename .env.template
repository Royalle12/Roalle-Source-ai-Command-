# ═══════════════════════════════════════════════════════════════
# ROYALLE SOURCE — ENVIRONMENT TEMPLATE
# Copy this file to .env and fill in your API keys.
# ═══════════════════════════════════════════════════════════════

# --- Google Gemini (for script generation) ---
# Get from: https://aistudio.google.com/
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# --- Pexels (for stock video footage) ---
# Get from: https://www.pexels.com/api/
PEXELS_API_KEY=YOUR_PEXELS_API_KEY

# --- ElevenLabs (for cloned voice - OPTIONAL) ---
# Get from: https://elevenlabs.io/
ELEVENLABS_API_KEY=YOUR_ELEVENLABS_API_KEY
VOICE_ID=YOUR_CLONED_VOICE_ID

# --- Meta / Instagram / Facebook ---
# Get from: https://developers.facebook.com/
# You need: Business Account + Facebook Page linked
INSTAGRAM_ACCOUNT_ID=YOUR_INSTAGRAM_ACCOUNT_ID
FACEBOOK_PAGE_ID=YOUR_FACEBOOK_PAGE_ID
META_ACCESS_TOKEN=YOUR_META_ACCESS_TOKEN

# --- YouTube ---
# Download client_secret.json from Google Cloud Console
# Place it in the social_agent/ folder
YOUTUBE_CLIENT_SECRET_FILE=client_secret.json
